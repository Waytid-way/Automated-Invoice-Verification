{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "pythonVersion": "3.11"
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "startCommand": "gunicorn webhook_server:app --bind :$PORT --workers 2 --timeout 120"
  }
}
